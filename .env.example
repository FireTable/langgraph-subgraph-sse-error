# Required — your OpenAI-compatible provider secret.
OPENAI_API_KEY=sk-...

# Optional — base URL of an OpenAI-compatible provider.
# Leave empty for stock OpenAI (https://api.openai.com/v1).
# Set to your provider (e.g. https://api.deepseek.com/v1) to repro against that endpoint.
OPENAI_BASE_URL=

# Optional — model name passed to the provider.
OPENAI_MODEL=gpt-4o-mini


LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=